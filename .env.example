# Database
POSTGRES_DB=questboard
POSTGRES_USER=questboard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API
BCRYPT_COST=12
API_TOKEN_TTL_HOURS=168
RESET_TOKEN_TTL_HOURS=2
APP_BASE_URL=https://deineURL.space

# Web
NEXT_PUBLIC_API_BASE=http://api:8080
AUTH_COOKIE_NAME=qb_token
AUTH_COOKIE_SECURE=true

# Initial superadmin (optional)
BOOTSTRAP_ADMIN_USERNAME=CHANGE_ME_ADMIN
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Optional initial member user (for RBAC smoke tests)
BOOTSTRAP_MEMBER_USERNAME=CHANGE_ME_MEMBER
BOOTSTRAP_MEMBER_PASSWORD=CHANGE_ME_MEMBER_PASSWORD
SMOKE_MEMBER_USERNAME=CHANGE_ME_MEMBER
SMOKE_MEMBER_PASSWORD=CHANGE_ME_MEMBER_PASSWORD

# Legal pages (optional, fallback to BOOTSTRAP_ADMIN_USERNAME for name)
LEGAL_CONTACT_NAME=CHANGE_ME_OR_LEAVE_EMPTY
LEGAL_CONTACT_EMAIL=CHANGE_ME_OR_LEAVE_EMPTY
LEGAL_CONTACT_COUNTRY=Deutschland

# Discord bot
DISCORD_TOKEN=CHANGE_ME_DISCORD_BOT_TOKEN
DISCORD_APP_ID=CHANGE_ME_DISCORD_APPLICATION_ID
DISCORD_PUBLIC_GUILD_ID=CHANGE_ME_PUBLIC_GUILD_ID
DISCORD_INTERNAL_GUILD_ID=CHANGE_ME_INTERNAL_GUILD_ID
DISCORD_ACTIVITY_ROLE_ID=CHANGE_ME_ACTIVITY_ROLE_ID
DISCORD_REPORT_CHANNEL_ID=CHANGE_ME_REPORT_CHANNEL_ID
# Optional: if set, only members with this role can run /checkactivity.
DISCORD_COMMAND_ROLE_ID=
DISCORD_CHECK_COMMAND_NAME=checkactivity
DISCORD_DIAGNOSE_COMMAND_NAME=activitystatus
DISCORD_CACHE_TTL_MS=60000
DISCORD_AUTO_REGISTER_COMMANDS=true
